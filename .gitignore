*.py[cod]
.runtime/

# Agent/session backups
*.bak
*.bak.*
*.20[0-9][0-9][0-9][0-9][0-9][0-9]*.bak

# Local reference symlink and original course assets
bigdata
*.zip
*.doc
*.docx
*.mp4
