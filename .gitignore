tutorial.txt

# Next.js frontend dependencies and build output
frontend/node_modules/
frontend/.next/
frontend/.next.bak-*/
frontend/tsconfig.tsbuildinfo

# Report command logs and local screenshots can contain host paths, device IDs,
# usernames, network names, or other machine-specific details.
reports/assets/*.log
reports/assets/*.png

